{
	"schemaVersion": "0.1.0",
	"name": "Geral",
	"behavior": "create",
	"noteContentFormat": "# {{title}}\n\n{{selectorHtml:body\n|remove_html:(\"style,script,noscript,header,footer,nav,aside,form,button,svg,canvas\")\n|remove_tags:\"a\"\n|markdown\n|trim\n}}",
	"properties": [
		{
			"name": "categoria",
			"value": "[[Clippings]]",
