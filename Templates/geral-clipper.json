		},
		{
			"name": "titulo",
			"value": "{{title}}",
			"type": "text"
		},
		{
			"name": "tags",
			"value": "clippings, web,",
			"type": "multitext"
		}
	],
	"triggers": [
		"/^https?:\\/\\/.*/"
	],
